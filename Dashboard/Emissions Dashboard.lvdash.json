{
  "datasets": [
    {
      "name": "cc09f24e",
      "displayName": "Location Data",
      "queryLines": [
        "SELECT latitude,\r\n",
        "longitude,\r\n",
        "`GHG emissions mtons CO2e` AS Emissions \r\n",
        "FROM emissions.default.emissions_data"
      ]
    },
    {
      "name": "b5ce5c9f",
      "displayName": "Emissions Per Person",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(\r\n",
        "        REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "        AS DOUBLE\r\n",
        "        ) / NULLIF (\r\n",
        "          CAST(\r\n",
        "            REPLACE(population, ',', '')\r\n",
        "            AS DOUBLE\r\n",
        "          ), 0\r\n",
        "        ) AS Emissions_per_person\r\n",
        "FROM emissions.default.emissions_data\r\n",
        "ORDER BY Emissions_per_person DESC\r\n"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "3896bb66",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "SELECT state_abbr,\r\n",
        "       SUM(CAST(\r\n",
        "        REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "        AS DOUBLE\r\n",
        "        ) ) AS Total_Emissions\r\n",
        "FROM emissions.default.emissions_data\r\n",
        "GROUP BY state_abbr\r\n",
        "ORDER BY Total_Emissions DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "df90fc35",
      "displayName": "Total Emissions Per County",
      "queryLines": [
        "SELECT county_state_name,\r\n",
        "       population,\r\n",
        "       CAST(\r\n",
        "        REPLACE(`GHG emissions mtons CO2e`, ',', '') \r\n",
        "        AS DOUBLE) AS Total_Emissions\r\n",
        "FROM emissions.default.emissions_data\r\n",
        "ORDER BY Total_Emissions DESC\r\n",
        "LIMIT 10"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
